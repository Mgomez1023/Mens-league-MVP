DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require
JWT_SECRET=replace-with-long-random-secret
JWT_ALG=HS256
JWT_EXPIRES_MIN=720
CORS_ALLOW_ORIGINS=https://mens-league-web.vercel.app,https://mens-league-mvp.vercel.app,http://localhost:5173,https://benitojuarezbaseball.com,https://www.benitojuarezbaseball.com
ADMIN_EMAIL=admin@league.local
ADMIN_PASSWORD=change-this-password
# Optional: where uploads are written in serverless (ephemeral on Vercel)
UPLOADS_DIR=/tmp/uploads
